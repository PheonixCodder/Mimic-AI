# mimic-ai environment variables
# Copy to .env.local and fill in values

# ── InsForge (from `npx @insforge/cli link` + `secrets get ANON_KEY`) ──
NEXT_PUBLIC_INSFORGE_URL=https://your-appkey.us-east.insforge.app
NEXT_PUBLIC_INSFORGE_ANON_KEY=your_anon_key
INSFORGE_API_KEY=your_api_key_from_.insforge/project.json

# ── App ──
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000

# ── Cloudflare R2 ──
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=mimic-ai

# ── Polar Billing (https://polar.sh) ──
POLAR_ACCESS_TOKEN=polar_oat_...
POLAR_SERVER=sandbox
POLAR_PRODUCT_ID=prod_...
POLAR_METER_VOICE_CLONE=voice_clone
POLAR_METER_AVATAR=avatar_generation
POLAR_METER_SCRIPT=script_generation
POLAR_METER_SCRIPT_PROPERTY=characters
POLAR_METER_VIDEO=video_generation
POLAR_METER_VIDEO_PROPERTY=compute_units

# ── Trigger.dev (https://cloud.trigger.dev) ──
TRIGGER_SECRET_KEY=tr_dev_...
TRIGGER_PROJECT_REF=proj_...

# ── Modal GPU services (deploy with `modal deploy modal/<app>.py`) ──
# Chatterbox TTS
CHATTERBOX_API_URL=https://your-workspace--chatterbox-tts-chatterbox-serve.modal.run
CHATTERBOX_API_KEY=your_mimic_api_key
# Talking avatar (AVATAR_MODE=simulate|hallo3)
TALKING_AVATAR_API_URL=https://your-workspace--mimic-talking-avatar-talkingavatar-serve.modal.run
TALKING_AVATAR_API_KEY=your_mimic_api_key
# AI clip generation — Wan2 GPU (modal deploy modal/video_generation.py)
# CPU simulate fallback — modal deploy modal/video_generation_simulate.py
VIDEO_GENERATION_API_URL=https://your-workspace--mimic-video-generation-videogeneration-web.modal.run
VIDEO_GENERATION_API_KEY=your_mimic_api_key
# Caption generation (CAPTION_GEN_MODE=simulate|whisper)
CAPTION_GENERATION_API_URL=https://your-workspace--mimic-caption-generation-captiongener-web.modal.run
CAPTION_GENERATION_API_KEY=your_mimic_api_key
# Video export composition (VIDEO_COMP_MODE=simulate|moviepy)
VIDEO_COMPOSITION_API_URL=https://your-workspace--mimic-video-composition-videocomposition-web.modal.run
VIDEO_COMPOSITION_API_KEY=your_mimic_api_key

# ── Cloudinary (https://cloudinary.com) ──
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ── Optional ──
# RESEND_API_KEY=re_...
# SKIP_ENV_VALIDATION=1
